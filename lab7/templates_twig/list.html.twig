<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Список рецептов</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <h1>Рецепты</h1>
  <a href="form.php">Добавить рецепт</a>
  <table border="1">
    <thead>
      <tr>
        <th>Название</th>
        <th>Время приготовления</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
    {%for recipe in recipes%}
      <tr>
        <td>{{ recipe.title }}</td>
        <td>{{ recipe.prep_time | format_duration }}</td>
        <td>
          <a href="edit.php?id={{ loop.index0 }}">✏️ Изменить</a>
          <a href="delete.php?id={{ loop.index0 }}" onclick="return confirm('Удалить?')">❌ Удалить</a>
        </td>
      </tr>
    {%endfor%}
    </tbody>
  </table>
</body>
</html>
